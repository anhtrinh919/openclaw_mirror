# Copy to .env and fill in real values.
# Get API credentials from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional session name prefix; actual session file lives under ./state/
TELEGRAM_SESSION_NAME=telethon

# Export behavior
EXPORT_ROOT=./output
EXPORT_TIMEZONE=UTC
# Leave blank to export all dialogs visible to the account.
# Or point to a newline-delimited file of chat usernames/IDs/titles.
EXPORT_TARGETS_FILE=./config/export_targets.txt
